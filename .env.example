# ============================================================
# Kantri Lawyer Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control.
# ============================================================


# ── DATABASE ─────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Example (local):     postgresql://postgres:mypass@localhost:5432/kantri_db
# Example (AWS RDS):   postgresql://postgres:mypass@mydb.xxxxx.rds.amazonaws.com:5432/kantri_db
# Example (Azure):     postgresql://postgres:mypass@myserver.postgres.database.azure.com:5432/kantri_db
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/kantri_db"


# ── APP ──────────────────────────────────────────────────────
# Set to "production" on the live server
NODE_ENV="production"

# Your domain (no trailing slash)
NEXT_PUBLIC_APP_URL="https://kantrilawyer.com"


# ── RAZORPAY PAYMENTS ─────────────────────────────────────────
# Get these from https://razorpay.com → Settings → API Keys
# Use test keys for testing, live keys for production
NEXT_PUBLIC_RAZORPAY_KEY="rzp_live_YOUR_KEY_HERE"
RAZORPAY_SECRET="YOUR_RAZORPAY_SECRET_HERE"


# ── EMAIL / SMTP ──────────────────────────────────────────────
# For contact form submissions and order notifications
# Supports: Gmail, AWS SES, SendGrid, any SMTP provider

# Using Gmail:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-gmail-app-password"  (use App Password, not your login password)

# Using AWS SES (recommended for production):
# SMTP_HOST="email-smtp.ap-south-1.amazonaws.com"
# SMTP_PORT="587"
# SMTP_USER="YOUR_SES_SMTP_USERNAME"
# SMTP_PASS="YOUR_SES_SMTP_PASSWORD"

SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@kantrilawyer.com"

# Admin email — where contact form messages + order alerts are sent
ADMIN_EMAIL="uday@kantrilawyer.com"


# ── FILE UPLOADS (optional — for cloud storage) ───────────────
# Currently, uploads are saved to local disk (/public/uploads/).
# If your hosting platform uses containers or serverless,
# switch to one of the options below.

# Option A: AWS S3
# AWS_REGION="ap-south-1"
# AWS_ACCESS_KEY_ID="AKIA_YOUR_ACCESS_KEY"
# AWS_SECRET_ACCESS_KEY="your-secret-access-key"
# AWS_S3_BUCKET="kantrilawyer-uploads"

# Option B: Azure Blob Storage
# AZURE_STORAGE_ACCOUNT="yourstorageaccount"
# AZURE_STORAGE_KEY="your-storage-account-key"
# AZURE_CONTAINER_NAME="uploads"

# Option C: Cloudinary (easiest)
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"
